# Copy this file to .env and fill in values
# Never commit .env

# Application
ENVIRONMENT=development
LOG_LEVEL=INFO

# Database (local: matches docker-compose.yml defaults)
DATABASE_URL=postgresql+asyncpg://genhealth:genhealth_dev@localhost:5433/genhealth

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# LLM Guardrails (optional overrides)
LLM_MAX_FILE_SIZE_MB=10
LLM_MAX_PAGES=20
LLM_MAX_TOKENS=256
LLM_REQUEST_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
LLM_RATE_LIMIT_PER_MINUTE=10
